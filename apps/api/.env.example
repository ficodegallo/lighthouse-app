# Database
DATABASE_URL="postgresql://lighthouse:password@localhost:5432/lighthouse_dev"

# AWS
AWS_REGION="us-east-1"
AWS_S3_BUCKET="lighthouse-audio-dev"
AWS_COGNITO_USER_POOL_ID="us-east-1_XXXXXXXXX"
AWS_COGNITO_CLIENT_ID="XXXXXXXXXXXXXXXXXXXXXXXXXX"
AWS_SNS_TOPIC_ARN="arn:aws:sns:us-east-1:000000000000:lighthouse-notifications-dev"

# Claude API
ANTHROPIC_API_KEY="sk-ant-..."

# ElevenLabs
ELEVENLABS_API_KEY="sk_..."
ELEVENLABS_DEFAULT_VOICE_ID="..."

# App
NODE_ENV="development"
PORT=3000
LOG_LEVEL="info"

# HIPAA: never log PII — this is enforced in the audit logger, not here
