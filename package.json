{
  "name": "lighthouse",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "infrastructure"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "api": "turbo dev --filter=api",
    "mobile": "turbo dev --filter=mobile"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "typescript": "^5.4.5",
    "prettier": "^3.2.5",
    "@types/node": "^20.12.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.5.0"
}
